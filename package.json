{
  "name": "@jisaacfriend/cyrano",
  "version": "0.1.0",
  "description": "Swap Claude spinner verbs from curated lists",
  "type": "module",
  "bin": {
    "cyrano": "dist/index.js"
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "prepublishOnly": "pnpm build"
  },
  "engines": {
    "node": ">=26"
  },
  "files": [
    "dist/",
    "lists/"
  ],
  "keywords": [
    "claude",
    "spinner",
    "cli"
  ],
  "license": "MIT",
  "dependencies": {
    "@inquirer/prompts": "^7.5.2"
  },
  "devDependencies": {
    "@types/node": "^22.15.21",
    "tsup": "^8.5.0",
    "typescript": "^5.8.3"
  }
}
